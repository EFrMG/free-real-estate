{
  "name": "@free-real-estate/node-drizzle",
  "description": "Local backend to be used with SQLite",
  "author": "EFrMG",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "generate": "drizzle-kit generate",
    "push": "drizzle-kit push",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@free-real-estate/shared": "workspace:*",
    "@hono/node-server": "^1.19.14",
    "@libsql/client": "^0.17.3",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
